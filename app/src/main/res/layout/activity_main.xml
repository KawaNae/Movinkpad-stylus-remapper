<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <!-- ═══ Header ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:background="@color/bg"
        android:elevation="2dp">

        <!-- Left: Logo + title -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@color/amber"/>

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stylus Remapper"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"
                android:layout_marginStart="10dp"/>

            <TextView
                android:id="@+id/tvVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v3.1.1"
                android:textSize="12sp"
                android:textColor="@color/text_muted"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Right: Status + power -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvShizukuStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Shizuku Connected"
                android:textSize="12sp"
                android:textColor="@color/text_muted"
                android:drawablePadding="6dp"
                android:background="@drawable/bg_status_badge"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"/>

            <TextView
                android:id="@+id/btnToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● 停止中"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_toggle_btn"
                android:paddingHorizontal="18dp"
                android:paddingVertical="8dp"
                android:layout_marginStart="12dp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border"/>

    <!-- ═══ Profile Bar ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:background="@color/bg">

        <Spinner
            android:id="@+id/spinnerProfile"
            android:layout_width="140dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_profile_dropdown"
            android:popupBackground="@color/bg_card"/>

        <Button android:id="@+id/btnProfileNew" android:layout_width="wrap_content" android:layout_height="28dp"
            android:text="新規" android:textSize="11sp" android:textColor="@color/text_muted" android:background="@drawable/bg_footer_btn"
            android:paddingHorizontal="10dp" android:layout_marginStart="8dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/btnProfileRename" android:layout_width="wrap_content" android:layout_height="28dp"
            android:text="名前変更" android:textSize="11sp" android:textColor="@color/text_muted" android:background="@drawable/bg_footer_btn"
            android:paddingHorizontal="10dp" android:layout_marginStart="4dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/btnProfileDelete" android:layout_width="wrap_content" android:layout_height="28dp"
            android:text="削除" android:textSize="11sp" android:textColor="@color/text_muted" android:background="@drawable/bg_footer_btn"
            android:paddingHorizontal="10dp" android:layout_marginStart="4dp" android:minWidth="0dp" android:minHeight="0dp"/>

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

        <TextView
            android:id="@+id/tvMappingSummary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="11sp"
            android:textColor="@color/text_muted"
            android:fontFamily="monospace"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border"/>

    <!-- ═══ Content ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- ─── Cards Area (LEFT) ─── -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BUTTON MAPPING"
                android:textSize="11sp"
                android:textColor="@color/text_muted"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.15"
                android:layout_marginBottom="12dp"/>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Card 3 (Switch 3) — topmost on the pen -->
                    <LinearLayout
                        android:id="@+id/card3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_card_expanded"
                        android:layout_marginBottom="12dp"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:id="@+id/cardHeader3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="14dp">

                            <TextView
                                android:id="@+id/cardNum3"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:gravity="center"
                                android:text="3"
                                android:textSize="13sp"
                                android:textColor="@color/amber"
                                android:fontFamily="monospace"
                                android:background="@drawable/bg_number_badge_active"/>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="12dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Switch 3" android:textSize="14sp" android:textColor="@color/text_primary" android:fontFamily="sans-serif-medium"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="同時押し" android:textSize="12sp" android:textColor="@color/text_secondary"/>
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvCurrentMapping3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ctrl+Z"
                                android:textSize="13sp"
                                android:textColor="@color/amber"
                                android:fontFamily="monospace"
                                android:background="@drawable/bg_amber_pill"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="4dp"/>

                            <TextView
                                android:id="@+id/chevron3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="▴"
                                android:textSize="16sp"
                                android:textColor="@color/amber"
                                android:layout_marginStart="10dp"/>
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp"
                            android:background="@color/border" android:id="@+id/cardDivider3"/>

                        <LinearLayout
                            android:id="@+id/cardBody3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp"
                            android:visibility="visible">

                            <LinearLayout
                                android:id="@+id/presetGrid3"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginBottom="16dp"/>

                            <View android:layout_width="match_parent" android:layout_height="1dp"
                                android:background="@color/border" android:layout_marginBottom="14dp"/>

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="CUSTOM" android:textSize="10sp" android:textColor="@color/text_muted"
                                android:fontFamily="sans-serif-medium" android:letterSpacing="0.12" android:layout_marginBottom="10dp"/>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                    android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="16dp">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                        android:text="修飾キー" android:textSize="11sp" android:textColor="@color/text_muted" android:layout_marginBottom="6dp"/>
                                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                                        <CheckBox android:id="@+id/cbCtrl3" android:layout_width="wrap_content" android:layout_height="36dp"
                                            android:text="Ctrl" android:textSize="12sp" android:textColor="@color/text_muted"
                                            android:button="@null" android:background="@drawable/bg_pill"
                                            android:paddingHorizontal="14dp" android:gravity="center" android:layout_marginEnd="6dp"
                                            android:minWidth="0dp"/>
                                        <CheckBox android:id="@+id/cbAlt3" android:layout_width="wrap_content" android:layout_height="36dp"
                                            android:text="Alt" android:textSize="12sp" android:textColor="@color/text_muted"
                                            android:button="@null" android:background="@drawable/bg_pill"
                                            android:paddingHorizontal="14dp" android:gravity="center" android:layout_marginEnd="6dp"
                                            android:minWidth="0dp"/>
                                        <CheckBox android:id="@+id/cbShift3" android:layout_width="wrap_content" android:layout_height="36dp"
                                            android:text="Shift" android:textSize="12sp" android:textColor="@color/text_muted"
                                            android:button="@null" android:background="@drawable/bg_pill"
                                            android:paddingHorizontal="14dp" android:gravity="center"
                                            android:minWidth="0dp"/>
                                    </LinearLayout>
                                </LinearLayout>

                                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                    android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="16dp">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                        android:text="キー" android:textSize="11sp" android:textColor="@color/text_muted" android:layout_marginBottom="6dp"/>
                                    <Spinner android:id="@+id/spinnerKey3" android:layout_width="match_parent" android:layout_height="36dp"
                                        android:background="@drawable/bg_profile_dropdown" android:popupBackground="@color/bg_card"/>
                                </LinearLayout>

                                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                    android:layout_weight="1" android:orientation="vertical">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                        android:text="マウスボタン" android:textSize="11sp" android:textColor="@color/text_muted" android:layout_marginBottom="6dp"/>
                                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                                        <CheckBox android:id="@+id/cbMouseL3" android:layout_width="wrap_content" android:layout_height="36dp"
                                            android:text="左" android:textSize="12sp" android:textColor="@color/text_muted"
                                            android:button="@null" android:background="@drawable/bg_pill"
                                            android:paddingHorizontal="14dp" android:gravity="center" android:layout_marginEnd="6dp" android:minWidth="0dp"/>
                                        <CheckBox android:id="@+id/cbMouseM3" android:layout_width="wrap_content" android:layout_height="36dp"
                                            android:text="中" android:textSize="12sp" android:textColor="@color/text_muted"
                                            android:button="@null" android:background="@drawable/bg_pill"
                                            android:paddingHorizontal="14dp" android:gravity="center" android:layout_marginEnd="6dp" android:minWidth="0dp"/>
                                        <CheckBox android:id="@+id/cbMouseR3" android:layout_width="wrap_content" android:layout_height="36dp"
                                            android:text="右" android:textSize="12sp" android:textColor="@color/text_muted"
                                            android:button="@null" android:background="@drawable/bg_pill"
                                            android:paddingHorizontal="14dp" android:gravity="center" android:minWidth="0dp"/>
                                    </LinearLayout>
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Card 2 -->
                    <LinearLayout
                        android:id="@+id/card2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_card"
                        android:layout_marginBottom="12dp"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:id="@+id/cardHeader2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="14dp">
                            <TextView android:id="@+id/cardNum2" android:layout_width="32dp" android:layout_height="32dp"
                                android:gravity="center" android:text="2" android:textSize="13sp" android:textColor="@color/text_muted"
                                android:fontFamily="monospace" android:background="@drawable/bg_number_badge"/>
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Switch 2" android:textSize="14sp" android:textColor="@color/text_primary" android:fontFamily="sans-serif-medium"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="上側ボタン" android:textSize="12sp" android:textColor="@color/text_secondary"/>
                            </LinearLayout>
                            <TextView android:id="@+id/tvCurrentMapping2" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Space" android:textSize="13sp" android:textColor="@color/amber" android:fontFamily="monospace"
                                android:background="@drawable/bg_amber_pill" android:paddingHorizontal="10dp" android:paddingVertical="4dp"/>
                            <TextView android:id="@+id/chevron2" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="▾" android:textSize="16sp" android:textColor="@color/text_muted" android:layout_marginStart="10dp"/>
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp"
                            android:background="@color/border" android:id="@+id/cardDivider2" android:visibility="gone"/>

                        <LinearLayout android:id="@+id/cardBody2" android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="vertical" android:padding="16dp" android:visibility="gone">
                            <LinearLayout android:id="@+id/presetGrid2" android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:orientation="vertical" android:layout_marginBottom="16dp"/>
                            <View android:layout_width="match_parent" android:layout_height="1dp"
                                android:background="@color/border" android:layout_marginBottom="14dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="CUSTOM" android:textSize="10sp" android:textColor="@color/text_muted"
                                android:fontFamily="sans-serif-medium" android:letterSpacing="0.12" android:layout_marginBottom="10dp"/>
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="16dp">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="修飾キー" android:textSize="11sp" android:textColor="@color/text_muted" android:layout_marginBottom="6dp"/>
                                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                                        <CheckBox android:id="@+id/cbCtrl2" android:layout_width="wrap_content" android:layout_height="36dp" android:text="Ctrl" android:textSize="12sp" android:textColor="@color/text_muted" android:button="@null" android:background="@drawable/bg_pill" android:paddingHorizontal="14dp" android:gravity="center" android:layout_marginEnd="6dp" android:minWidth="0dp"/>
                                        <CheckBox android:id="@+id/cbAlt2" android:layout_width="wrap_content" android:layout_height="36dp" android:text="Alt" android:textSize="12sp" android:textColor="@color/text_muted" android:button="@null" android:background="@drawable/bg_pill" android:paddingHorizontal="14dp" android:gravity="center" android:layout_marginEnd="6dp" android:minWidth="0dp"/>
                                        <CheckBox android:id="@+id/cbShift2" android:layout_width="wrap_content" android:layout_height="36dp" android:text="Shift" android:textSize="12sp" android:textColor="@color/text_muted" android:button="@null" android:background="@drawable/bg_pill" android:paddingHorizontal="14dp" android:gravity="center" android:minWidth="0dp"/>
                                    </LinearLayout>
                                </LinearLayout>
                                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="16dp">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="キー" android:textSize="11sp" android:textColor="@color/text_muted" android:layout_marginBottom="6dp"/>
                                    <Spinner android:id="@+id/spinnerKey2" android:layout_width="match_parent" android:layout_height="36dp" android:background="@drawable/bg_profile_dropdown" android:popupBackground="@color/bg_card"/>
                                </LinearLayout>
                                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="マウスボタン" android:textSize="11sp" android:textColor="@color/text_muted" android:layout_marginBottom="6dp"/>
                                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                                        <CheckBox android:id="@+id/cbMouseL2" android:layout_width="wrap_content" android:layout_height="36dp" android:text="左" android:textSize="12sp" android:textColor="@color/text_muted" android:button="@null" android:background="@drawable/bg_pill" android:paddingHorizontal="14dp" android:gravity="center" android:layout_marginEnd="6dp" android:minWidth="0dp"/>
                                        <CheckBox android:id="@+id/cbMouseM2" android:layout_width="wrap_content" android:layout_height="36dp" android:text="中" android:textSize="12sp" android:textColor="@color/text_muted" android:button="@null" android:background="@drawable/bg_pill" android:paddingHorizontal="14dp" android:gravity="center" android:layout_marginEnd="6dp" android:minWidth="0dp"/>
                                        <CheckBox android:id="@+id/cbMouseR2" android:layout_width="wrap_content" android:layout_height="36dp" android:text="右" android:textSize="12sp" android:textColor="@color/text_muted" android:button="@null" android:background="@drawable/bg_pill" android:paddingHorizontal="14dp" android:gravity="center" android:minWidth="0dp"/>
                                    </LinearLayout>
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Card 1 (Switch 1) — pen-tip side, lowest on the pen -->
                    <LinearLayout
                        android:id="@+id/card1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_card"
                        android:layout_marginBottom="12dp"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:id="@+id/cardHeader1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="14dp">
                            <TextView android:id="@+id/cardNum1" android:layout_width="32dp" android:layout_height="32dp"
                                android:gravity="center" android:text="1" android:textSize="13sp" android:textColor="@color/text_muted"
                                android:fontFamily="monospace" android:background="@drawable/bg_number_badge"/>
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Switch 1" android:textSize="14sp" android:textColor="@color/text_primary" android:fontFamily="sans-serif-medium"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="ペン先側ボタン" android:textSize="12sp" android:textColor="@color/text_secondary"/>
                            </LinearLayout>
                            <TextView android:id="@+id/tvCurrentMapping1" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Ctrl+Alt" android:textSize="13sp" android:textColor="@color/amber" android:fontFamily="monospace"
                                android:background="@drawable/bg_amber_pill" android:paddingHorizontal="10dp" android:paddingVertical="4dp"/>
                            <TextView android:id="@+id/chevron1" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="▾" android:textSize="16sp" android:textColor="@color/text_muted" android:layout_marginStart="10dp"/>
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp"
                            android:background="@color/border" android:id="@+id/cardDivider1" android:visibility="gone"/>

                        <LinearLayout android:id="@+id/cardBody1" android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="vertical" android:padding="16dp" android:visibility="gone">
                            <LinearLayout android:id="@+id/presetGrid1" android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:orientation="vertical" android:layout_marginBottom="16dp"/>
                            <View android:layout_width="match_parent" android:layout_height="1dp"
                                android:background="@color/border" android:layout_marginBottom="14dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="CUSTOM" android:textSize="10sp" android:textColor="@color/text_muted"
                                android:fontFamily="sans-serif-medium" android:letterSpacing="0.12" android:layout_marginBottom="10dp"/>
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="16dp">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="修飾キー" android:textSize="11sp" android:textColor="@color/text_muted" android:layout_marginBottom="6dp"/>
                                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                                        <CheckBox android:id="@+id/cbCtrl1" android:layout_width="wrap_content" android:layout_height="36dp" android:text="Ctrl" android:textSize="12sp" android:textColor="@color/text_muted" android:button="@null" android:background="@drawable/bg_pill" android:paddingHorizontal="14dp" android:gravity="center" android:layout_marginEnd="6dp" android:minWidth="0dp"/>
                                        <CheckBox android:id="@+id/cbAlt1" android:layout_width="wrap_content" android:layout_height="36dp" android:text="Alt" android:textSize="12sp" android:textColor="@color/text_muted" android:button="@null" android:background="@drawable/bg_pill" android:paddingHorizontal="14dp" android:gravity="center" android:layout_marginEnd="6dp" android:minWidth="0dp"/>
                                        <CheckBox android:id="@+id/cbShift1" android:layout_width="wrap_content" android:layout_height="36dp" android:text="Shift" android:textSize="12sp" android:textColor="@color/text_muted" android:button="@null" android:background="@drawable/bg_pill" android:paddingHorizontal="14dp" android:gravity="center" android:minWidth="0dp"/>
                                    </LinearLayout>
                                </LinearLayout>
                                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="16dp">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="キー" android:textSize="11sp" android:textColor="@color/text_muted" android:layout_marginBottom="6dp"/>
                                    <Spinner android:id="@+id/spinnerKey1" android:layout_width="match_parent" android:layout_height="36dp" android:background="@drawable/bg_profile_dropdown" android:popupBackground="@color/bg_card"/>
                                </LinearLayout>
                                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="マウスボタン" android:textSize="11sp" android:textColor="@color/text_muted" android:layout_marginBottom="6dp"/>
                                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                                        <CheckBox android:id="@+id/cbMouseL1" android:layout_width="wrap_content" android:layout_height="36dp" android:text="左" android:textSize="12sp" android:textColor="@color/text_muted" android:button="@null" android:background="@drawable/bg_pill" android:paddingHorizontal="14dp" android:gravity="center" android:layout_marginEnd="6dp" android:minWidth="0dp"/>
                                        <CheckBox android:id="@+id/cbMouseM1" android:layout_width="wrap_content" android:layout_height="36dp" android:text="中" android:textSize="12sp" android:textColor="@color/text_muted" android:button="@null" android:background="@drawable/bg_pill" android:paddingHorizontal="14dp" android:gravity="center" android:layout_marginEnd="6dp" android:minWidth="0dp"/>
                                        <CheckBox android:id="@+id/cbMouseR1" android:layout_width="wrap_content" android:layout_height="36dp" android:text="右" android:textSize="12sp" android:textColor="@color/text_muted" android:button="@null" android:background="@drawable/bg_pill" android:paddingHorizontal="14dp" android:gravity="center" android:minWidth="0dp"/>
                                    </LinearLayout>
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </ScrollView>
        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="@color/border"/>

        <!-- ─── Pen Column (RIGHT) ─── -->
