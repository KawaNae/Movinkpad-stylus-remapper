<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/tvShizukuStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Shizuku: Checking..."
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvRemapperStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Remapper: Stopped"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnToggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Start"
            android:enabled="false"
            android:layout_marginBottom="32dp" />

        <!-- Profile section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="プロファイル"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinnerProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_horizontal"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/btnProfileNew"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="新規"
                style="?android:attr/buttonBarButtonStyle"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnProfileRename"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="名前変更"
                style="?android:attr/buttonBarButtonStyle"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnProfileDelete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="削除"
                style="?android:attr/buttonBarButtonStyle"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Button settings section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ボタン設定"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- Button 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ボタン1 (ペン先側)"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/spinnerPreset1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <CheckBox
                    android:id="@+id/cbCtrl1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ctrl" />

                <CheckBox
                    android:id="@+id/cbAlt1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Alt" />

                <CheckBox
                    android:id="@+id/cbShift1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Shift" />
            </LinearLayout>

            <Spinner
                android:id="@+id/spinnerKey1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Button 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ボタン2 (中央)"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/spinnerPreset2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <CheckBox
                    android:id="@+id/cbCtrl2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ctrl" />

                <CheckBox
                    android:id="@+id/cbAlt2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Alt" />

                <CheckBox
                    android:id="@+id/cbShift2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Shift" />
            </LinearLayout>

            <Spinner
                android:id="@+id/spinnerKey2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Button 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ボタン3 (遠い側)"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/spinnerPreset3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <CheckBox
                    android:id="@+id/cbCtrl3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ctrl" />

                <CheckBox
                    android:id="@+id/cbAlt3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Alt" />

                <CheckBox
                    android:id="@+id/cbShift3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Shift" />
            </LinearLayout>

            <Spinner
                android:id="@+id/spinnerKey3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
