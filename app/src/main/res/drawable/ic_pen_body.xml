<?xml version="1.0" encoding="utf-8"?>
<!--
  Wacom Pro Pen 3 — solid cylinder + cone, drawn as ONE silhouette.
  Real dimensions 160.0 x 8.4 mm → aspect ratio ≈ 19:1.
  Viewport authored 1:1 with the layout dp (28 x 461), barrel = 24 units wide,
  total pen length = 455 units → 455 / 24 ≈ 19:1.

  Single path + one horizontal gradient (dark edge → light centre → dark edge) so the
  cylindrical shading runs continuously into the cone with no seam. Flat (squared) top
  edge because the barrel is a cylinder seen side-on, not a domed cap.
  No grip lines, no eraser cap, no button wells: extraneous decoration removed.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="28dp"
    android:height="461dp"
    android:viewportWidth="28"
    android:viewportHeight="461">

    <path android:pathData="M 2,2 L 26,2 L 26,424 L 14,457 L 2,424 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="2" android:startY="0"
                android:endX="26" android:endY="0"
                android:startColor="#323232"
                android:centerColor="#585858"
                android:endColor="#323232"/>
        </aapt:attr>
    </path>
</vector>
